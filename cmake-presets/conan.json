{
    "version": 7,
    "configurePresets": [
        {
            "name": "conan-debug",
            "hidden": true,
            "description": "Conan settings for debug build configuration",
            "environment": {
                "CONAN_HOME": "${sourceDir}/build/debug/.conan2"
            },
            "cacheVariables": {
                "CMAKE_PROJECT_TOP_LEVEL_INCLUDES":
                    "${sourceDir}/project-config/cmake-conan/conan_provider.cmake",
                "CONAN_INSTALL_ARGS":
                    "-c;tools.cmake.cmaketoolchain:user_presets=False;--build=missing",
                "CONAN_INSTALL_BUILD_CONFIGURATIONS": "Debug"
            }
        },
        {
            "name": "conan-release",
            "hidden": true,
            "description": "Conan settings for release build configuration",
            "environment": {
                "CONAN_HOME": "${sourceDir}/build/release/.conan2"
            },
            "cacheVariables": {
                "CMAKE_PROJECT_TOP_LEVEL_INCLUDES":
                    "${sourceDir}/project-config/cmake-conan/conan_provider.cmake",
                "CONAN_INSTALL_ARGS":
                    "-c;tools.cmake.cmaketoolchain:user_presets=False;--build=missing",
                "CONAN_INSTALL_BUILD_CONFIGURATIONS": "Release"
            }
        },
        {
            "name": "conan-relwithdebinfo",
            "hidden": true,
            "description": "Conan settings for RelWithDebInfo build configuration",
            "environment": {
                "CONAN_HOME": "${sourceDir}/build/relwithdebinfo/.conan2"
            },
            "cacheVariables": {
                "CMAKE_PROJECT_TOP_LEVEL_INCLUDES":
                    "${sourceDir}/project-config/cmake-conan/conan_provider.cmake",
                "CONAN_INSTALL_ARGS":
                    "-c;tools.cmake.cmaketoolchain:user_presets=False;--build=missing",
                "CONAN_INSTALL_BUILD_CONFIGURATIONS": "RelWithDebInfo"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "conan-debug",
            "hidden": true
        },
        {
            "name": "conan-release",
            "hidden": true
        },
        {
            "name": "conan-relwithdebinfo",
            "hidden": true
        }
    ],
    "testPresets": [
        {
            "name": "conan-debug",
            "hidden": true
        },
        {
            "name": "conan-release",
            "hidden": true
        },
        {
            "name": "conan-relwithdebinfo",
            "hidden": true
        }
    ]
}
