{
    "version": 7,
    "configurePresets": [
        {
            "name": "default-base",
            "hidden": true,
            "generator": "Ninja"
        },
        {
            "name": "default-debug",
            "hidden": true,
            "inherits": [
                "default-base"
            ],
            "displayName": "Debug",
            "description": "Default settings for debug build configuration",
            "binaryDir": "${sourceDir}/build/debug",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug"
            }
        },
        {
            "name": "default-release",
            "hidden": true,
            "inherits": [
                "default-base"
            ],
            "displayName": "Release",
            "description": "Default settings for release build configuration",
            "binaryDir": "${sourceDir}/build/release",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release"
            }
        },
        {
            "name": "default-relwithdebinfo",
            "hidden": true,
            "inherits": [
                "default-base"
            ],
            "displayName": "RelWithDebInfo",
            "description":
                "Optimized build with debug info and no LTO, for fast local iteration on release-level performance",
            "binaryDir": "${sourceDir}/build/relwithdebinfo",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "RelWithDebInfo"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "default-debug",
            "hidden": true,
            "configuration": "Debug"
        },
        {
            "name": "default-release",
            "hidden": true,
            "configuration": "Release"
        },
        {
            "name": "default-relwithdebinfo",
            "hidden": true,
            "configuration": "RelWithDebInfo"
        }
    ],
    "testPresets": [
        {
            "name": "default-debug",
            "hidden": true,
            "configuration": "Debug"
        },
        {
            "name": "default-release",
            "hidden": true,
            "configuration": "Release"
        },
        {
            "name": "default-relwithdebinfo",
            "hidden": true,
            "configuration": "RelWithDebInfo"
        }
    ]
}
